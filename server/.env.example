PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/lms_vaizai
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
OPENAI_API_KEY=your_openai_api_key_here

# Redis
REDIS_URL=redis://127.0.0.1:6379

# SMTP Email Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@lmsvaizai.com



# Base Configs
BASE_URL=http://localhost:5000

# AI Service Configuration
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_MS=30000
AI_CACHE_TTL=86400
# Cost per 1k tokens (USD) — update for your model
OPENAI_COST_INPUT_1K=0.0005
OPENAI_COST_OUTPUT_1K=0.0015

# File Storage Provider — 'local', 's3', or 'gcs'
STORAGE_PROVIDER=local

# AWS S3 (only required when STORAGE_PROVIDER=s3)
AWS_BUCKET_NAME=your_s3_bucket_name
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Google Cloud Storage (only required when STORAGE_PROVIDER=gcs)
GCS_BUCKET_NAME=your_gcs_bucket_name
# Auth: use key file OR standard GOOGLE_APPLICATION_CREDENTIALS
GCS_KEY_FILE=./service-account.json
# Optional GCS settings
GCS_PROJECT_ID=your_gcs_project_id
GCS_PUBLIC_BUCKET=false

# Virus Scanning
# Set to 'true' to enable ClamAV scanning (clamscan must be installed on the server)
VIRUS_SCAN_ENABLED=false
# Set to 'true' to REJECT uploads when ClamAV is unavailable (strict mode)
VIRUS_SCAN_STRICT=false

# Auth Token Configurations
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ENCRYPTION_KEY=your_encryption_key_here_must_be_32_bytes
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

